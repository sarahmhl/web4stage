{
  "name": "web4all/web4stage",
  "description": "Projet pedagogique CESI de gestion de stages.",
  "type": "project",
  "require": {},
  "require-dev": {
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {
    "psr-4": {
      "Core\\": "core/",
      "App\\Controllers\\": "app/Controllers/",
      "App\\Models\\": "app/Models/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "config": {
    "process-timeout": 900,
    "preferred-install": {
      "*": "dist"
    }
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml"
  }
}
